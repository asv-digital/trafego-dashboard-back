generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id                String    @id @default(cuid())
  name              String
  type              String
  audience          String?
  dailyBudget       Float
  startDate         DateTime
  status            String    @default("Ativa")
  // Fase de aprendizado (Passo 9)
  createdInMetaAt   DateTime?
  learningPhaseEnd  DateTime?
  isInLearningPhase Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  metrics   MetricEntry[]
  creatives Creative[]
  sales     Sale[]
}

// Configuração de automação do agente (Passo 6)
model AutomationConfig {
  id                      String   @id @default(uuid())
  autoPauseNoSales        Boolean  @default(true)
  autoPauseSpendLimit     Float    @default(200)
  autoPauseBreakeven      Boolean  @default(true)
  breakevenCPA            Float    @default(93.60)
  breakevenMinDays        Int      @default(3)
  autoScaleWinners        Boolean  @default(true)
  autoScaleCPAThreshold   Float    @default(50)
  autoScalePercent        Float    @default(20)
  autoScaleMinDays        Int      @default(3)
  autoScaleMaxBudget      Float    @default(200)
  respectLearningPhase    Boolean  @default(true)
  learningPhaseHours      Int      @default(72)
  autoRotateCreatives     Boolean  @default(false)
  notifyOnAutoAction      Boolean  @default(true)
  cpaPauseThreshold       Float    @default(70)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model MetricEntry {
  id           String   @id @default(cuid())
  date         DateTime
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSet        String?
  investment   Float
  impressions  Int
  clicks       Int
  sales        Int
  frequency    Float?
  hookRate     Float?
  observations String?

  // Melhoria 4: Funil completo + Hook Rate + CPLPV
  landingPageViews       Int?
  initiateCheckouts      Int?
  addToCart              Int?
  costPerPageView        Float?
  costPerCheckout        Float?
  costPerLandingPageView Float?
  clickToPageViewRate    Float?
  pageViewToCheckout     Float?
  checkoutToSaleRate     Float?
  outboundClicks         Int?
  outboundCtr            Float?
  threeSecondViews       Int?
  videoPlays             Int?

  // Ponto 8: ThruPlay
  thruplayViews    Int?
  thruplayRate     Float?

  createdAt DateTime @default(now())
}

model Creative {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String   @default("Ativo")
  ctr         Float?
  hookRate    Float?
  cpa         Float?
  thruplayRate Float?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Melhoria 2: Modelo Sale com atribuição UTM
model Sale {
  id                String    @id @default(uuid())
  date              DateTime
  amountGross       Float
  amountNet         Float
  paymentMethod     String
  status            String    @default("approved")
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  metaCampaignId    String?
  metaAdsetId       String?
  metaAdId          String?
  customerEmail     String?
  customerPhone     String?
  customerName      String?
  customerFirstName String?
  customerLastName  String?
  kirvanoTxId       String    @unique
  kirvanoCheckoutId String?
  capiSent          Boolean   @default(false)
  capiSentAt        DateTime?
  capiEventId       String?
  convertedToMentoria  Boolean   @default(false)
  mentoriaConvertedAt  DateTime?
  campaignId        String?
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Melhoria 3: Carrinho abandonado
model CartAbandonment {
  id            String   @id @default(uuid())
  date          DateTime
  customerEmail String?
  customerPhone String?
  customerName  String?
  productId     String?
  utmSource     String?
  utmCampaign   String?
  utmContent    String?
  checkoutUrl   String?
  recovered     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// Melhoria 8: Backup diário
model DailySnapshot {
  id                String   @id @default(uuid())
  date              DateTime @unique
  totalSpend        Float
  totalSales        Int
  totalRevenue      Float
  avgCpa            Float
  avgRoas           Float
  avgCtr            Float
  avgCpm            Float
  avgFrequency      Float
  hookRate          Float?
  cplpv             Float?
  outboundCtr       Float?
  campaignBreakdown Json?
  collectedAt       DateTime @default(now())
  source            String   @default("agent")
  createdAt         DateTime @default(now())
}

// Melhoria 22: CPM por posicionamento
model PlacementMetric {
  id             String   @id @default(uuid())
  date           DateTime
  campaignId     String?
  adsetId        String?
  platform       String
  position       String
  impressions    Int
  spend          Float
  cpm            Float
  clicks         Int
  outboundClicks Int?
  conversions    Int?
  cpa            Float?
  createdAt      DateTime @default(now())
}

// Melhoria 17: Log de ações
model ActionLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  entityName String
  details    String?
  source     String   @default("dashboard")
  executedAt DateTime @default(now())
}

// Melhoria 31: Metas mensais
model MonthlyGoal {
  id          String   @id @default(uuid())
  month       String   @unique
  targetSales Int
  targetCpa   Float
  targetRoas  Float
  targetProfit Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Notificações WhatsApp (Passo 0)
model NotificationConfig {
  id                    String   @id @default(uuid())
  whatsappProvider      String   @default("z-api") // "z-api" ou "evolution"
  whatsappInstanceId    String?
  whatsappToken         String?
  whatsappPhone         String?  // 5511999999999
  enabled               Boolean  @default(true)
  notifyAutoActions     Boolean  @default(true)
  notifyCreativeActions Boolean  @default(true)
  notifyLearningPhase   Boolean  @default(true)
  notifyAlerts          Boolean  @default(true)
  notifyDailySummary    Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NotificationLog {
  id        String   @id @default(uuid())
  type      String   // 'auto_action' | 'creative' | 'learning_phase' | 'alert' | 'daily_summary'
  message   String
  channel   String   @default("whatsapp")
  status    String   // 'sent' | 'failed'
  error     String?
  createdAt DateTime @default(now())
}

// Ponto 6: Diagnóstico de qualidade por ad
model AdDiagnostic {
  id                String   @id @default(uuid())
  date              DateTime
  adId              String
  adName            String
  adsetId           String
  campaignId        String
  qualityRanking    String   // 'ABOVE_AVERAGE_10' ... 'BELOW_AVERAGE_35'
  engagementRanking String
  conversionRanking String
  spend             Float
  cpa               Float?
  createdAt         DateTime @default(now())

  @@unique([date, adId])
}

// Ponto 1: Coordenação entre automações (Automation Lock)
model AutomationLock {
  id            String   @id @default(uuid())
  entityType    String   // 'adset' | 'campaign'
  entityId      String   // ID do ad set ou campanha
  lockedBy      String   // 'auto_executor' | 'budget_rebalancer' | 'dayparting' | 'ab_resolver'
  action        String   // 'scale' | 'pause' | 'budget_change' | 'daypart_reduce' | 'daypart_restore'
  previousValue Float?   // budget antes da ação
  newValue      Float?   // budget depois da ação
  expiresAt     DateTime // lock expira automaticamente
  createdAt     DateTime @default(now())

  @@unique([entityType, entityId])
}

// Ponto 2: Dead Man's Switch (Heartbeat)
model AgentHeartbeat {
  id                  String    @id @default(uuid())
  lastCollectionAt    DateTime?
  lastSnapshotAt      DateTime?
  lastAutomationAt    DateTime?
  consecutiveFailures Int       @default(0)
  lastError           String?
  updatedAt           DateTime  @updatedAt
}

// Ponto 9: CPM Trend
model CPMTrend {
  id               String   @id @default(uuid())
  date             DateTime @unique
  avgCPM           Float
  avgCTR           Float
  avgCPA           Float
  totalSpend       Float
  totalImpressions Int
  note             String?
  createdAt        DateTime @default(now())
}

// Ponto 10: Comentários de Ads
model AdComment {
  id         String    @id @default(uuid())
  adId       String
  adName     String
  commentId  String    @unique
  message    String
  authorName String?
  sentiment  String?   // 'positive' | 'negative' | 'objection_price' | 'objection_trust' | 'question' | 'tag_friend' | 'neutral'
  createdAt  DateTime
  analyzedAt DateTime?
}

model AdCommentSummary {
  id             String   @id @default(uuid())
  adId           String
  adName         String
  period         String   // '7d'
  totalComments  Int
  positive       Int
  negative       Int
  objectionPrice Int
  objectionTrust Int
  questions      Int
  tagFriend      Int
  neutral        Int
  topObjection   String?
  recommendation String?
  analyzedAt     DateTime @default(now())

  @@unique([adId, period])
}

// Ponto 11: Lookalike Audiences
model LookalikeAudience {
  id                   String   @id @default(uuid())
  name                 String
  metaAudienceId       String?
  sourceAudienceId     String
  percentage           Float
  buyerCountAtCreation Int
  status               String   @default("created") // 'created' | 'testing' | 'active' | 'paused'
  testAdsetId          String?
  createdAt            DateTime @default(now())
}

// Melhoria 33: Testes A/B
model CreativeTest {
  id                 String    @id @default(uuid())
  name               String
  status             String    @default("running")
  adsetId            String
  variantA           Json
  variantB           Json
  startDate          DateTime
  endDate            DateTime?
  minDays            Int       @default(5)
  minSpendPerVariant Float     @default(150)
  winner             String?
  confidence         Float?
  decidedAt          DateTime?
  createdAt          DateTime  @default(now())
}
