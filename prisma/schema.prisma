generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  type        String
  audience    String?
  dailyBudget Float
  startDate   DateTime
  status      String   @default("Ativa")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics   MetricEntry[]
  creatives Creative[]
  sales     Sale[]
}

model MetricEntry {
  id           String   @id @default(cuid())
  date         DateTime
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSet        String?
  investment   Float
  impressions  Int
  clicks       Int
  sales        Int
  frequency    Float?
  hookRate     Float?
  observations String?

  // Melhoria 4: Funil completo + Hook Rate + CPLPV
  landingPageViews       Int?
  initiateCheckouts      Int?
  addToCart              Int?
  costPerPageView        Float?
  costPerCheckout        Float?
  costPerLandingPageView Float?
  clickToPageViewRate    Float?
  pageViewToCheckout     Float?
  checkoutToSaleRate     Float?
  outboundClicks         Int?
  outboundCtr            Float?
  threeSecondViews       Int?
  videoPlays             Int?

  createdAt DateTime @default(now())
}

model Creative {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String   @default("Ativo")
  ctr         Float?
  hookRate    Float?
  cpa         Float?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Melhoria 2: Modelo Sale com atribuição UTM
model Sale {
  id                String    @id @default(uuid())
  date              DateTime
  amountGross       Float
  amountNet         Float
  paymentMethod     String
  status            String    @default("approved")
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  metaCampaignId    String?
  metaAdsetId       String?
  metaAdId          String?
  customerEmail     String?
  customerPhone     String?
  customerName      String?
  customerFirstName String?
  customerLastName  String?
  kirvanoTxId       String    @unique
  kirvanoCheckoutId String?
  capiSent          Boolean   @default(false)
  capiSentAt        DateTime?
  capiEventId       String?
  convertedToMentoria  Boolean   @default(false)
  mentoriaConvertedAt  DateTime?
  campaignId        String?
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Melhoria 3: Carrinho abandonado
model CartAbandonment {
  id            String   @id @default(uuid())
  date          DateTime
  customerEmail String?
  customerPhone String?
  customerName  String?
  productId     String?
  utmSource     String?
  utmCampaign   String?
  utmContent    String?
  checkoutUrl   String?
  recovered     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// Melhoria 8: Backup diário
model DailySnapshot {
  id                String   @id @default(uuid())
  date              DateTime @unique
  totalSpend        Float
  totalSales        Int
  totalRevenue      Float
  avgCpa            Float
  avgRoas           Float
  avgCtr            Float
  avgCpm            Float
  avgFrequency      Float
  hookRate          Float?
  cplpv             Float?
  outboundCtr       Float?
  campaignBreakdown Json?
  collectedAt       DateTime @default(now())
  source            String   @default("agent")
  createdAt         DateTime @default(now())
}
